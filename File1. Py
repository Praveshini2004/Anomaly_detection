import random
import io
import matplotlib.pyplot as plt
import xlsxwriter

# Create an Excel file and add a worksheet
workbook = xlsxwriter.Workbook('cpu_utilization_graphs.xlsx')
worksheet = workbook.add_worksheet()

# Set column width for better image display
worksheet.set_column('A:A', 20)

# Generate and insert 1000 graphs
for i in range(1000):
    # Simulated CPU utilization data (e.g., 60 seconds)
    cpu_data = [random.randint(0, 100) for _ in range(60)]

    # Plotting the CPU utilization graph
    plt.figure(figsize=(4, 2))
    plt.plot(cpu_data, color='green')
    plt.title(f'CPU Utilization {i + 1}')
    plt.xlabel('Time (s)')
    plt.ylabel('Utilization (%)')
    plt.tight_layout()

    # Save the plot to an in-memory buffer
    img_buf = io.BytesIO()
    plt.savefig(img_buf, format='png')
    plt.close()
    img_buf.seek(0)

    # Insert image into Excel (each row spaced by 20 for visibility)
    row = i * 20
    worksheet.insert_image(row, 0, f'cpu_graph_{i+1}.png', {'image_data': img_buf})

# Close the workbook
workbook.close()
print("Excel file created with 1000 CPU utilization graphs.")
