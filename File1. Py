import random
import io
import matplotlib.pyplot as plt
import xlsxwriter

# Create an Excel file and add a worksheet
workbook = xlsxwriter.Workbook('cpu_utilization_graphs.xlsx')
worksheet = workbook.add_worksheet()

# Set column width for better image display
worksheet.set_column('A:A', 20)

# Generate and insert 1000 graphs
for i in range(1000):
    # Simulated CPU utilization data (e.g., 60 seconds)
    cpu_data = [random.randint(0, 100) for _ in range(60)]

    # Plotting the CPU utilization graph
    plt.figure(figsize=(4, 2))
    plt.plot(cpu_data, color='green')
    plt.title(f'CPU Utilization {i + 1}')
    plt.xlabel('Time (s)')
    plt.ylabel('Utilization (%)')
    plt.tight_layout()

    # Save the plot to an in-memory buffer
    img_buf = io.BytesIO()
    plt.savefig(img_buf, format='png')
    plt.close()
    img_buf.seek(0)

    # Insert image into Excel (each row spaced by 20 for visibility)
    row = i * 20
    worksheet.insert_image(row, 0, f'cpu_graph_{i+1}.png', {'image_data': img_buf})

# Close the workbook
workbook.close()
print("Excel file created with 1000 CPU utilization graphs.")




import os
import numpy as np
import matplotlib.pyplot as plt
import zipfile

# Folder to store images temporarily
output_folder = 'cpu_images'
os.makedirs(output_folder, exist_ok=True)

# Generate 1000 images
for i in range(1, 1001):
    # Simulate CPU utilization data (e.g., over 60 seconds)
    time = np.arange(60)
    utilization = np.clip(np.random.normal(loc=50, scale=20, size=60), 0, 100)  # bounded between 0 and 100

    # Plot and save image
    plt.figure(figsize=(6, 4))
    plt.plot(time, utilization, color='blue', linewidth=2)
    plt.title(f'CPU Utilization - Sample {i}')
    plt.xlabel('Time (s)')
    plt.ylabel('CPU Usage (%)')
    plt.ylim(0, 100)
    plt.grid(True)

    image_path = os.path.join(output_folder, f'cpu_utilization_{i:04}.png')
    plt.savefig(image_path)
    plt.close()

print("Images generated.")

# Create a ZIP file
zip_filename = 'cpu_utilization_images.zip'
with zipfile.ZipFile(zip_filename, 'w') as zipf:
    for filename in os.listdir(output_folder):
        filepath = os.path.join(output_folder, filename)
        zipf.write(filepath, arcname=filename)

print(f"All images have been zipped into {zip_filename}")

